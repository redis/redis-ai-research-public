{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "redis-cloud-mcp": {
      "type": "local",
      "command": ["uv", "run", "python", "mcps/mcp_redis_cloud_server.py"],
      "enabled": true,
      "environment": {
        "LOG_LEVEL": "INFO"
      }
    }
    // Add additional MCP servers here, e.g.:
    // "mermaid-render": {
    //   "type": "local",
    //   "command": ["uv", "run", "python", "/absolute/path/to/your/mermaid/server.py"]
    // }
  }
}
