# Required: the Agents SDK reads this for the default model client.
OPENAI_API_KEY=sk-your-key-here

# Model every tenant uses unless they override it. Set to a model your
# account can access (names change over time).
DEFAULT_MODEL=gpt-5.1

# unix_local (dev only, NOT isolated) | docker (one container per task)
SANDBOX_BACKEND=unix_local
DOCKER_IMAGE=python:3.12-slim

# Per-task safety rails
MAX_TURNS=30
TASK_TIMEOUT_SECONDS=600

# Local workspaces root (used by the local_dir workspace kind)
WORKSPACES_ROOT=./_workspaces

# Optional: path to a tenants file. If unset, a built-in demo registry is used.
# TENANTS_FILE=./tenants.json

# Postgres connection string. Required to use /v1/sessions endpoints.
# DATABASE_URL=postgresql://agent:agent@localhost:5432/agent
# DB_POOL_MAX_SIZE=10
